# Copy to .env and fill in real values. Never commit .env with secrets.

# Django (generate a new key for production)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Redis: Celery broker/result (DB 0) and optional override for cache
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1

# Apollo.io: mixed companies search (Recruiter Info tab)
APOLLO_API_KEY=

# CompanyEnrich (server-side only)
COMPANY_ENRICH_API_KEY=

# Temporary first-run admin (server-side only; change for any deployment)
BOOTSTRAP_ADMIN_EMAIL=hireai.default.admin@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=

# Playwright job scrapers (tasks/automation).
# By default the scrapers launch concurrent Chromium profiles from
# backend/browser-userdata/<platform>. Set PLAYWRIGHT_USE_CDP=1 to attach to
# an existing Chrome remote-debugging session instead.
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
PLAYWRIGHT_USE_CDP=
# Set to 1 to disable all Playwright scraping (use only tasks/automation/*.json exports)
DISABLE_PLAYWRIGHT_AUTOMATION=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gmail SMTP for email MFA.
# Use a Google account app password, not the normal Gmail password:
# Google Account > Security > 2-Step Verification > App passwords.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=Hire AI <your-gmail-address@gmail.com>
MFA_CODE_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
