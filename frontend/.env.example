# Copy to .env (gitignored) for local Vite. Variables prefixed with VITE_ are exposed to the client.

# Do NOT put secrets in the frontend. Keep API keys on the backend.
# (Gemini is currently used in-browser only when a user pastes their own key in Settings.)

# Optional: when not using the Vite dev proxy, set your API origin (no trailing slash)
# VITE_API_URL=http://127.0.0.1:8000

# Optional: public app URL for links / OAuth (if you use it in the app)
# APP_URL=http://localhost:5173
